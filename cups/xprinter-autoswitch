#!/bin/bash
# Auto-detect Xprinter connection (USB or Bluetooth) and configure CUPS.
#
# Usage:
#   xprinter-autoswitch              — detect and switch
#   xprinter-autoswitch --status     — show current connection
#
# Called automatically by udev when USB printer is plugged/unplugged.

PRINTER_NAME="XprinterV3"
BT_ADDRESS=""  # Will be read from saved config or CUPS

# Known Xprinter USB vendor IDs
XPRINTER_USB_VIDS="0483 154f 4b43 0416 1fc9"

log() {
    logger -t xprinter-autoswitch "$1"
    echo "$1"
}

# Find Bluetooth address from current CUPS config or bluetoothctl
get_bt_address() {
    # Try current CUPS URI
    local uri
    uri=$(lpstat -v "$PRINTER_NAME" 2>/dev/null | grep -oP 'xprinter-bt://\K[A-Fa-f0-9]+')
    if [ -n "$uri" ]; then
        echo "$uri" | sed 's/\(..\)/\1:/g; s/:$//' | tr 'a-f' 'A-F'
        return
    fi

    # Try bluetoothctl
    local addr
    addr=$(bluetoothctl devices 2>/dev/null | grep -iE "xp|xprinter|printer|label" | head -1 | awk '{print $2}')
    if [ -n "$addr" ]; then
        echo "$addr"
        return
    fi

    # Try saved config
    if [ -f /etc/xprinter-bt-address ]; then
        cat /etc/xprinter-bt-address
        return
    fi
}

# Find USB printer — returns CUPS USB URI
find_usb_uri() {
    # Ask CUPS for connected USB devices
    local usb_uri
    usb_uri=$(lpinfo -v 2>/dev/null | grep -i "usb://" | grep -iE "xprinter|4barcode|3b-t|label|printer-80" | head -1 | awk '{print $2}')
    if [ -n "$usb_uri" ]; then
        echo "$usb_uri"
        return 0
    fi

    # Fallback: check by known vendor IDs in sysfs
    for dev in /dev/usb/lp*; do
        [ -e "$dev" ] || continue
        local basename
        basename=$(basename "$dev")
        for sysdev in /sys/class/usbmisc/"$basename"/device/../; do
            local vid
            vid=$(cat "${sysdev}idVendor" 2>/dev/null)
            for known_vid in $XPRINTER_USB_VIDS; do
                if [ "$vid" = "$known_vid" ]; then
                    echo "usb://$dev"
                    return 0
                fi
            done
        done
    done

    # Fallback: serial USB
    for dev in /dev/ttyUSB*; do
        [ -e "$dev" ] || continue
        echo "serial:${dev}?baud=9600"
        return 0
    done

    return 1
}

# Get current CUPS URI
get_current_uri() {
    lpstat -v "$PRINTER_NAME" 2>/dev/null | awk '{print $NF}'
}

show_status() {
    local uri
    uri=$(get_current_uri)
    local usb_uri
    usb_uri=$(find_usb_uri 2>/dev/null)

    echo "=== Xprinter Connection Status ==="
    echo "CUPS URI:    ${uri:-not configured}"

    if echo "$uri" | grep -q "usb://\|serial:.*ttyUSB"; then
        echo "Connection:  USB"
    elif echo "$uri" | grep -q "xprinter-bt://"; then
        echo "Connection:  Bluetooth"
    else
        echo "Connection:  unknown"
    fi

    if [ -n "$usb_uri" ]; then
        echo "USB device:  $usb_uri (connected)"
    else
        echo "USB device:  not connected"
    fi

    local bt_addr
    bt_addr=$(get_bt_address)
    if [ -n "$bt_addr" ]; then
        local bt_connected
        bt_connected=$(bluetoothctl info "$bt_addr" 2>/dev/null | grep "Connected: yes")
        if [ -n "$bt_connected" ]; then
            echo "Bluetooth:   $bt_addr (connected)"
        else
            echo "Bluetooth:   $bt_addr (paired, not connected)"
        fi
    else
        echo "Bluetooth:   not configured"
    fi
}

switch_to_usb() {
    local uri="$1"

    local current
    current=$(get_current_uri)
    if [ "$current" = "$uri" ]; then
        log "Already on USB: $uri"
        return 0
    fi

    log "Switching to USB: $uri"

    # Remove auto-created duplicate printer (CUPS may auto-add USB printers)
    for dup in $(lpstat -a 2>/dev/null | awk '{print $1}' | grep -v "$PRINTER_NAME" | grep -v "Phaser"); do
        local dup_uri
        dup_uri=$(lpstat -v "$dup" 2>/dev/null | awk '{print $NF}')
        if echo "$dup_uri" | grep -qi "4barcode\|3b-t\|xprinter\|printer-80"; then
            log "Removing duplicate printer: $dup ($dup_uri)"
            lpadmin -x "$dup" 2>/dev/null || true
        fi
    done

    lpadmin -p "$PRINTER_NAME" -v "$uri" -E 2>/dev/null
    cupsenable "$PRINTER_NAME" 2>/dev/null
    cupsaccept "$PRINTER_NAME" 2>/dev/null
}

switch_to_bluetooth() {
    local bt_addr="$1"
    local bt_flat
    bt_flat=$(echo "$bt_addr" | tr -d ':')
    local uri="xprinter-bt://${bt_flat}"

    local current
    current=$(get_current_uri)
    if [ "$current" = "$uri" ]; then
        log "Already on Bluetooth: $uri"
        return 0
    fi

    log "Switching to Bluetooth: $uri"
    lpadmin -p "$PRINTER_NAME" -v "$uri" -E 2>/dev/null
    cupsenable "$PRINTER_NAME" 2>/dev/null
    cupsaccept "$PRINTER_NAME" 2>/dev/null
}

watch_loop() {
    log "Watching for connection changes..."
    local last_uri=""
    while true; do
        local current
        current=$(get_current_uri)
        local usb_uri
        usb_uri=$(find_usb_uri 2>/dev/null)

        if [ -n "$usb_uri" ] && ! echo "$current" | grep -q "usb://"; then
            switch_to_usb "$usb_uri"
        elif [ -z "$usb_uri" ] && echo "$current" | grep -q "usb://"; then
            local bt_addr
            bt_addr=$(get_bt_address)
            if [ -n "$bt_addr" ]; then
                switch_to_bluetooth "$bt_addr"
            fi
        fi
        sleep 3
    done
}

main() {
    if [ "$1" = "--status" ]; then
        show_status
        exit 0
    fi

    if [ "$1" = "--watch" ]; then
        watch_loop
        exit 0
    fi

    # Check if printer exists in CUPS
    if ! lpstat -p "$PRINTER_NAME" >/dev/null 2>&1; then
        log "Printer $PRINTER_NAME not found in CUPS. Run install-cups.sh first."
        exit 1
    fi

    # Try USB first (faster, more reliable)
    local usb_uri
    usb_uri=$(find_usb_uri 2>/dev/null)
    if [ -n "$usb_uri" ]; then
        switch_to_usb "$usb_uri"
        exit 0
    fi

    # Fall back to Bluetooth
    local bt_addr
    bt_addr=$(get_bt_address)
    if [ -n "$bt_addr" ]; then
        switch_to_bluetooth "$bt_addr"
        exit 0
    fi

    log "No Xprinter found (USB or Bluetooth)"
    exit 1
}

main "$@"
